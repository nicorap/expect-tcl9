# Commands covered: Tcl 9 compatibility layer
#
# Tests for the Tcl 9 port: channel encoding profiles, open override,
# case->switch alias, and non-ASCII pattern matching.
#
# Run individually:
#   expect tests/tcl9compat.test
# Run via make:
#   make test

if {[lsearch [namespace children] ::tcltest] == -1} {
    package require tcltest
    namespace import ::tcltest::test ::tcltest::cleanupTests
}
package require Expect

log_user 0

proc mktmpfile {} {
    # Tcl 9: [file tempfile varName] returns the channel; varName gets the path.
    # Tcl 8: [file tempfile varName] returns the path; varName gets the channel.
    if {[catch {set chan [file tempfile path]}]} {
        # Tcl 8 fallback
        set path [file tempfile chan]
        close $chan
    } else {
        close $chan
    }
    return $path
}

# ---------------------------------------------------------------------------
# stdin/stdout/stderr profile (set at package load time)
# ---------------------------------------------------------------------------

test tcl9compat-1.1 {stdin has -profile tcl8} {
    fconfigure stdin -profile
} {tcl8}

test tcl9compat-1.2 {stdout has -profile tcl8} {
    fconfigure stdout -profile
} {tcl8}

test tcl9compat-1.3 {stderr has -profile tcl8} {
    fconfigure stderr -profile
} {tcl8}

# ---------------------------------------------------------------------------
# Spawned channel profile
# ---------------------------------------------------------------------------

test tcl9compat-2.1 {spawned channel has -profile tcl8} {
    exp_spawn cat /dev/null
    set profile [fconfigure $spawn_id -profile]
    exp_wait
    set profile
} {tcl8}

# High bytes (0x80-0xFF) must survive the round-trip through a spawned
# channel without triggering an encoding error.
test tcl9compat-2.2 {spawned channel carries high bytes without encoding error} {
    set tmp [mktmpfile]
    set f [open $tmp wb]
    puts -nonewline $f "abc\x80\xfe\xff"
    close $f

    set result NONE
    exp_spawn cat $tmp
    expect {
        -re ".+" { set result [string length $expect_out(0,string)] }
        timeout  { set result TIMEOUT }
        eof      { set result EOF }
    }
    exp_wait
    file delete $tmp
    set result
} {6}

# ---------------------------------------------------------------------------
# [open] override — files opened via Tcl's [open] must also get tcl8 profile
# ---------------------------------------------------------------------------

test tcl9compat-3.1 {[open] for writing gets -profile tcl8} {
    set tmp [mktmpfile]
    set f [open $tmp w]
    set profile [fconfigure $f -profile]
    close $f
    file delete $tmp
    set profile
} {tcl8}

test tcl9compat-3.2 {[open] for reading gets -profile tcl8} {
    set tmp [mktmpfile]
    set f [open $tmp r]
    set profile [fconfigure $f -profile]
    close $f
    file delete $tmp
    set profile
} {tcl8}

test tcl9compat-3.3 {[open] still functions normally after profile override} {
    set tmp [mktmpfile]
    set f [open $tmp w]
    puts $f "hello tcl9"
    close $f
    set f [open $tmp r]
    set line [gets $f]
    close $f
    file delete $tmp
    set line
} {hello tcl9}

test tcl9compat-3.4 {[open] with access mode argument works} {
    set tmp [mktmpfile]
    set f [open $tmp {WRONLY CREAT TRUNC}]
    puts $f "mode test"
    close $f
    set f [open $tmp r]
    set line [gets $f]
    close $f
    file delete $tmp
    set line
} {mode test}

# ---------------------------------------------------------------------------
# case -> switch alias (case was removed in Tcl 9)
# ---------------------------------------------------------------------------

test tcl9compat-4.1 {case matches correct branch} {
    case abc {
        abc     { set x 1 }
        default { set x 0 }
    }
    set x
} {1}

test tcl9compat-4.2 {case falls through to default} {
    case xyz {
        abc     { set x 1 }
        default { set x 2 }
    }
    set x
} {2}

test tcl9compat-4.3 {case selects among multiple patterns} {
    case b {
        a { set x 1 }
        b { set x 2 }
        c { set x 3 }
    }
    set x
} {2}

test tcl9compat-4.4 {case with -exact flag (switch compat)} {
    case -exact ab {
        a  { set x 1 }
        ab { set x 2 }
        b  { set x 3 }
    }
    set x
} {2}

# ---------------------------------------------------------------------------
# Non-ASCII pattern matching (exercises Tcl_UtfToUniChar in string_first /
# string_case_first and retoglob)
# ---------------------------------------------------------------------------

# Exact match of a multi-byte UTF-8 sequence (U+00E9, "é").
# Write it as a unicode character; Tcl encodes it as UTF-8 (0xC3 0xA9) on disk.
# The spawned channel (tcl8 profile, utf-8 encoding) decodes it back to U+00E9.
test tcl9compat-5.1 {exact match of UTF-8 multi-byte sequence} {
    set tmp [mktmpfile]
    set f [open $tmp w]
    puts -nonewline $f "\u00e9\n"
    close $f

    set result NONE
    exp_spawn cat $tmp
    expect {
        -ex "\u00e9" { set result MATCH }
        timeout      { set result TIMEOUT }
        eof          { set result EOF }
    }
    exp_wait
    file delete $tmp
    set result
} {MATCH}

# Glob match with non-ASCII prefix.
test tcl9compat-5.2 {glob pattern with non-ASCII character} {
    set tmp [mktmpfile]
    set f [open $tmp w]
    puts -nonewline $f "\u00e9hello\n"
    close $f

    set result NONE
    exp_spawn cat $tmp
    expect {
        "\u00e9*" { set result MATCH }
        timeout   { set result TIMEOUT }
        eof       { set result EOF }
    }
    exp_wait
    file delete $tmp
    set result
} {MATCH}

# Case-insensitive exact match with ASCII (exercises string_case_first).
test tcl9compat-5.3 {case-insensitive exact match} {
    set tmp [mktmpfile]
    set f [open $tmp w]
    puts -nonewline $f "Hello\n"
    close $f

    set result NONE
    exp_spawn cat $tmp
    expect {
        -nocase -ex "hello" { set result MATCH }
        timeout              { set result TIMEOUT }
        eof                  { set result EOF }
    }
    exp_wait
    file delete $tmp
    set result
} {MATCH}

# ---------------------------------------------------------------------------
# log_file binary passthrough (exercises -profile tcl8 in exp_log.c)
# ---------------------------------------------------------------------------

# Writing high bytes through the log channel must not raise an error.
test tcl9compat-6.1 {log_file passes high bytes without encoding error} {
    set tmp [mktmpfile]
    # -a writes to log regardless of log_user setting
    log_file -a $tmp
    # Send high bytes through; they appear in the log.
    set tmp2 [mktmpfile]
    set f [open $tmp2 wb]
    puts -nonewline $f "\x80\xfe\xff"
    close $f
    exp_spawn cat $tmp2
    expect eof
    exp_wait
    log_file
    set size [file size $tmp]
    file delete $tmp $tmp2
    # Log file must be non-empty (bytes written without error).
    expr {$size > 0}
} {1}

::tcltest::cleanupTests
